<?xml version="1.0" encoding="utf-8"?>
<!--
  Play Games Services identifiers.

  Replace each REPLACE_* value with the real id from Play Console once the Play Games Services
  project and its leaderboards are created. Until then the app runs fine; online leaderboard
  calls are guarded and no-op (see PlayGamesLeaderboard).

  - game_services_project_id : the numeric Play Games Services project id (NOT the GCP project
    number). Found in Play Console > Play Games Services > Configuration.
  - leaderboard_*            : the leaderboard ids, format CgkI...EAIQAQ.
-->
<resources>
    <string name="game_services_project_id" translatable="false">REPLACE_WITH_PGS_PROJECT_ID</string>
    <string name="leaderboard_beginner" translatable="false">REPLACE_WITH_BEGINNER_LEADERBOARD_ID</string>
    <string name="leaderboard_intermediate" translatable="false">REPLACE_WITH_INTERMEDIATE_LEADERBOARD_ID</string>
    <string name="leaderboard_expert" translatable="false">REPLACE_WITH_EXPERT_LEADERBOARD_ID</string>
</resources>
